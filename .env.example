# =============================================================================
# Cortex Second Brain — Environment Variables
# =============================================================================
# Copy this file to .env.local and fill in your values.
# NEVER commit .env.local to source control.
#
# ⚠️  The Supabase client uses VITE_SUPABASE_PUBLISHABLE_KEY (the anon/public
#     key), NOT VITE_SUPABASE_ANON_KEY. The variable name below is correct.
# =============================================================================

# -----------------------------------------------------------------------------
# Supabase — REQUIRED
# Get these from: https://supabase.com/dashboard/project/<ref>/settings/api
# -----------------------------------------------------------------------------
VITE_SUPABASE_URL=https://<project-ref>.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=<your-anon-public-key>
VITE_SUPABASE_PROJECT_ID=<your-project-ref>

# -----------------------------------------------------------------------------
# AI Provider Keys — Set as Supabase Edge Function secrets in production
# Only needed locally for running edge functions via `supabase functions serve`
# -----------------------------------------------------------------------------
# OPENAI_API_KEY=sk-...
# ANTHROPIC_API_KEY=sk-ant-...
# GOOGLE_AI_API_KEY=AIza...

# -----------------------------------------------------------------------------
# Google Drive Integration — Set as Supabase Edge Function secrets
# Create credentials at: https://console.cloud.google.com/apis/credentials
# -----------------------------------------------------------------------------
# GOOGLE_CLIENT_ID=...apps.googleusercontent.com
# GOOGLE_CLIENT_SECRET=GOCSPX-...

# -----------------------------------------------------------------------------
# Email (Resend) — Set as Supabase Edge Function secret
# Required for the send-backup-email edge function
# Get from: https://resend.com/api-keys
# -----------------------------------------------------------------------------
# RESEND_API_KEY=re_...

# -----------------------------------------------------------------------------
# Analytics & Monitoring — Optional
# -----------------------------------------------------------------------------
# VITE_ANALYTICS_ID=your_analytics_id

# -----------------------------------------------------------------------------
# API Behaviour — Optional (all have defaults shown)
# -----------------------------------------------------------------------------

# Maximum number of retry attempts for failed requests (default: 3)
# VITE_MAX_RETRIES=3

# Base delay in ms for exponential backoff (default: 1000)
# VITE_RETRY_DELAY=1000

# Maximum delay in ms for exponential backoff (default: 10000)
# VITE_MAX_RETRY_DELAY=10000

# Default timeout for API requests in ms (default: 30000)
# VITE_API_TIMEOUT=30000

# Backoff multiplier for retry delays (default: 2)
# VITE_BACKOFF_MULTIPLIER=2

# -----------------------------------------------------------------------------
# Cache Configuration — Optional (all have defaults shown)
# -----------------------------------------------------------------------------

# Default TTL for cached items in ms (default: 600000 = 10 minutes)
# VITE_CACHE_TTL=600000

# Maximum number of items to cache (default: 1000)
# VITE_MAX_CACHE_SIZE=1000

# Whether to enable service worker caching (default: true)
# VITE_SW_CACHE_ENABLED=true

# -----------------------------------------------------------------------------
# Rate Limiting — Optional (all have defaults shown)
# -----------------------------------------------------------------------------

# Default max requests per window (default: 60)
# VITE_RATE_LIMIT_MAX=60

# Default window size in ms (default: 60000 = 1 minute)
# VITE_RATE_LIMIT_WINDOW=60000

# -----------------------------------------------------------------------------
# Feature Flags — Optional (all enabled by default, set to 'false' to disable)
# -----------------------------------------------------------------------------

# Enable prefetching of data (default: true)
# VITE_PREFETCH_ENABLED=true

# Enable offline mode support (default: true)
# VITE_OFFLINE_MODE=true

# Enable performance monitoring / Web Vitals (default: true)
# VITE_PERF_MONITORING=true

# Enable debug logging in development (default: true in dev)
# VITE_DEBUG=true

# Enable virtual scrolling for long lists (default: true)
# VITE_VIRTUAL_SCROLL=true

# -----------------------------------------------------------------------------
# UI Configuration — Optional (all have defaults shown)
# -----------------------------------------------------------------------------

# Default page size for paginated lists (default: 50)
# VITE_DEFAULT_PAGE_SIZE=50

# Maximum page size allowed (default: 200)
# VITE_MAX_PAGE_SIZE=200

# Debounce delay for search inputs in ms (default: 300)
# VITE_SEARCH_DEBOUNCE=300

# Toast notification duration in ms (default: 5000)
# VITE_TOAST_DURATION=5000

# -----------------------------------------------------------------------------
# Background Sync — Optional (all have defaults shown)
# -----------------------------------------------------------------------------

# Maximum retry attempts for failed sync operations (default: 5)
# VITE_SYNC_MAX_RETRIES=5

# Initial retry delay in ms (default: 1000)
# VITE_SYNC_RETRY_DELAY=1000

# Maximum retry delay in ms (default: 300000 = 5 minutes)
# VITE_SYNC_MAX_DELAY=300000

# Debounce time for sync queue processing in ms (default: 500)
# VITE_SYNC_DEBOUNCE=500

# -----------------------------------------------------------------------------
# Batch Operations — Optional (all have defaults shown)
# -----------------------------------------------------------------------------

# Default batch size for bulk operations (default: 50)
# VITE_BATCH_SIZE=50

# Maximum batch size allowed (default: 200)
# VITE_MAX_BATCH_SIZE=200

# Delay between batches in ms (default: 100)
# VITE_BATCH_DELAY=100

# -----------------------------------------------------------------------------
# External API Timeouts — Optional (all have defaults shown)
# -----------------------------------------------------------------------------

# Timeout for OpenAI API calls in ms (default: 60000 = 1 minute)
# VITE_OPENAI_TIMEOUT=60000

# Timeout for geolocation API calls in ms (default: 5000)
# VITE_GEO_TIMEOUT=5000

# -----------------------------------------------------------------------------
# Node / Build — Optional
# -----------------------------------------------------------------------------
# NODE_ENV=development
